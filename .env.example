# --- Telegram ---
# Токен вашего Telegram-бота. Получается у @BotFather в Telegram. (Обязательно)
TELEGRAM_BOT_TOKEN=

# ID вашего Telegram-канала (публичного или частного). Для публичного: @username, для частного: -100... (Обязательно)
TELEGRAM_CHANNEL_ID=

# --- Администраторы ---
# ID администраторов для получения уведомлений и доступа к админ-командам.
# Можно указать несколько ID через запятую.
TELEGRAM_ADMIN_IDS=

# Одиночный ID администратора. Используется для обратной совместимости.
# Если указан TELEGRAM_ADMIN_IDS, эту переменную можно оставить пустой.
TELEGRAM_ADMIN_ID=


# --- AI Models (Google Gemini) ---
# Ключи Google API для доступа к моделям Gemini.
# Рекомендуемый способ: указать все ключи через запятую в GOOGLE_API_KEYS.
GOOGLE_API_KEYS=

# Для обратной совместимости можно также использовать отдельные переменные.
# GOOGLE_API_KEY будет иметь приоритет над ключами из списка.
GOOGLE_API_KEY=
GOOGLE_API_KEY_1=

# Имя модели Gemini для использования.
GEMINI_MODEL_NAME="models/gemini-1.5-flash-latest"
