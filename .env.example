# --- Telegram ---
# Токен вашего Telegram-бота. Получается у @BotFather в Telegram.
TELEGRAM_BOT_TOKEN=
# ID вашего основного Telegram-канала или группы (публичного или частного). Для публичного: @username, для частного: -100...
TELEGRAM_CHANNEL_ID=
# ID администраторов бота через запятую для доступа к админ-командам и получения уведомлений.
TELEGRAM_ADMIN_IDS=
# ID отдельного Telegram-канала или группы для публикации премиум-дайджестов.
# Канал/группа может быть приватным. Бот должен быть участником (и администратором, если это канал).
PREMIUM_DIGEST_CHANNEL_ID=

# --- AI Models ---
# Основной ключ Google API.
GOOGLE_API_KEY=
# Дополнительные ключи (опционально, для распределения нагрузки).
GOOGLE_API_KEY_1=

# Имя модели Gemini для использования.
GEMINI_MODEL_NAME="models/gemini-2.0-flash-thinking-exp-01-21"