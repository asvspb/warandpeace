[flake8]
max-line-length = 120
exclude = 
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    *.egg-info,
    .pytest_cache,
    .mypy_cache,
    migrations
ignore = 
    # Black handles whitespace
    E203,
    W503,
    # Allow lambda assignments  
    E731,
    # Allow bare excepts in specific cases
    E722
per-file-ignores =
    # Allow imports at bottom of __init__.py
    __init__.py:F401,E402
    # Allow long lines in tests
    tests/*.py:E501
max-complexity = 10
statistics = true
count = true
show-source = true
